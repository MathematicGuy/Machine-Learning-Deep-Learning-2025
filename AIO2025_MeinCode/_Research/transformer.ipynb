    "class DecoderBlock(nn.Module):\n",
    "    def __init__(self, d_model: int, multi_attention_block: MultiHeadAttention, cross_attention_block: MultiHeadAttention, feed_forward: PositionwiseFeedForward, dropout:float=0.5):\n",
    "        super().__init__()\n",
    "        self.self_attention_block = multi_attention_block\n",
    "        # Initialize 3 nn.Module\n",
    "        self.cross_attention_block = cross_attention_block\n",
    "        self.feed_forward = feed_forward\n",
    "        #? mask_size = sequence length\n",
    "        # self.look_ahead_mask = torch.triu(torch.ones(mask_size, mask_size), diagonal=1).bool()\n",
    "        self.resnet = nn.ModuleList([ResidualConnection(d_model, dropout=dropout) for _ in range(3)])\n",
    "\n",
    "\n",
    "    def forward(self, x_decoder: torch.Tensor, encoder_output: torch.Tensor, src_mask: torch.Tensor, tgt_mask: torch.Tensor):\n",
    "        \"\"\"Decoder the Query. Like Youtubem, you input search Query and its Output Key (title) and Value (video description)\n",
    "        Args:\n",
    "            x_decoder (torch.Tensor): torch.Tensor, Input Q of the Decoder (batch_size, seq_len, d_model)\n",
    "\n",
    "            encoder_output (torch.Tensor):  torch.Tensor\n",
    "                                    Key and Value from Encoder (batch_size, num_heads, q_seq_len, k_seq_len)\n",
    "                                    Example: (batch_size, 1, 1, src_seq_len).\n",
    "\n",
    "            Code Note: Must Apply tgt_mask first because it a NxN matrix whereas src_mask is 1xN matrix, so not compatible if we apply src_mask first.\n",
    "            tgt_mask (torch.Tensor): Target Mask. Hide next token in Next Token Prediction Training\n",
    "                                    Shape needs to be broadcastable to\n",
    "                                    (batch_size, num_heads, tgt_seq_len, src_seq_len)\n",
    "                                    Example: (batch_size, 1, tgt_seq_len, tgt_seq_len).\n",
    "\n",
    "            src_mask (torch.Tensor): For Padding [PAD] to make sequence length is equal\n",
    "                                    Shape needs to be broadcastable to\n",
    "                                    (batch_size, num_heads, tgt_seq_len, src_seq_len).\n",
    "                                    Example: (batch_size, 1, 1, src_seq_len).\n",
    "\n",
    "        Returns:\n",
    "            Predicted Word: torch.Tensor\n",
    "        \"\"\"\n",
    "\n",
    "        #? Masked Multi-Head Attention\n",
    "        masked_mha_out = self.resnet[0].forward(x_decoder, lambda x_res : self.self_attention_block(x_res, x_res, x_res, tgt_mask))\n",
    "\n",
    "        #? Apply Multi-Head Cross-Attention (Encoder-Decoder) with Add & Norm\n",
    "        mha_out = self.resnet[1].forward(masked_mha_out, lambda x_res : self.cross_attention_block(x_res, encoder_output, encoder_output, src_mask))\n",
    "        ff_out = self.resnet[2].forward(mha_out, self.feed_forward)\n",
    "\n",
    "        return ff_out"
   ]
  },
