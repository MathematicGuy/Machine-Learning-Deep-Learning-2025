    "class Decoder(nn.Module):\n",
    "    def __init__(self, d_model: int, decoder_stack: nn.ModuleList) -> None:\n",
    "        super().__init__()\n",
    "        self.decoder_stack = decoder_stack\n",
    "        self.layer_norm = LayerNormalization(d_model)\n",
    "\n",
    "    def forward(self, x_decoder: torch.Tensor, x_encoder: torch.Tensor, mask: torch.Tensor, look_ahead_mask: torch.Tensor):\n",
    "        for decoder in self.decoder_stack:\n",
    "            x_decoder = decoder(x_decoder, x_encoder, mask, look_ahead_mask)\n",
    "\n",
    "        return self.layer_norm(x_decoder)"
   ]
  },
