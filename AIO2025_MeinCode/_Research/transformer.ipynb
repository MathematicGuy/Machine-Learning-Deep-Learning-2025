    "print(\"\\n--- Masked Scaled Dot-Product Attention ---\")\n",
    "\n",
    "# Parameters (Example)\n",
    "batch_size_test = 4\n",
    "num_heads_test = 8 # Number of attention heads (will be relevant in Part 3)\n",
    "\n",
    "#? Test if Question Seq Length is different than Output Seq Length\n",
    "seq_len_q_test = 5 # Sequence length for queries\n",
    "seq_len_k_test = 7 # Sequence length for keys/values\n",
    "\n",
    "d_k_test = 64 // num_heads_test # Dimension of keys/queries per head\n",
    "d_v_test = 64 // num_heads_test # Dimension of values per head\n",
    "d_model_test = 64 # Total model dimension (d_k * num_heads)\n",
    "\n",
    "#! Check Raw-MHA\n",
    "Q = torch.randn(batch_size_test, num_heads_test, seq_len_q_test, d_k_test)\n",
    "K = torch.randn(batch_size_test, num_heads_test, seq_len_k_test, d_k_test)\n",
    "V = torch.randn(batch_size_test, num_heads_test, seq_len_k_test, d_k_test)\n",
    "\n",
    "attention_no_mask, weights_no_mask = scaled_dot_product_attention(Q, K, V)\n",
    "print('attention_no_mask\\n', attention_no_mask.shape)\n",
    "\n",
    "#! Check Masked-MHA\n",
    "#? Create QKV\n",
    "# batch_size, head_num, seq_len, d_model\n",
    "Q = torch.randn(batch_size_test, num_heads_test, seq_len_q_test, d_k_test)\n",
    "K = torch.randn(batch_size_test, num_heads_test, seq_len_k_test, d_k_test)\n",
    "V = torch.randn(batch_size_test, num_heads_test, seq_len_k_test, d_k_test)\n",
    "\n",
    "#? Create Boolean Mask with Dim = Dot-Prod Dim\n",
    "look_ahead_mask = torch.triu(torch.ones(seq_len_q_test, seq_len_k_test), diagonal=1).bool()\n",
    "look_ahead_mask = look_ahead_mask.squeeze(0).squeeze(0) # add batch, and head dim to Equal to scaled_dot_product_attention dimension\n",
    "print('MASK:\\n', look_ahead_mask)\n",
    "\n",
    "#? Initiaze Scaled-Dot-Product Attention and Apply Mask\n",
    "attention_mask, weights_mask = scaled_dot_product_attention(Q, K, V, mask=look_ahead_mask)\n",
    "print(f\"Output shape (masked): {attention_mask.shape}\")   # Expected: [2, 8, 5, 8]\n",
