    "\n",
    "\n",
    "#? Basic Components\n",
    "self_attention = MultiHeadAttention(m_dim, num_heads, dropout)\n",
    "feed_forward = PositionwiseFeedForward(m_dim, d_ff, dropout)\n",
    "\n",
    "# Create Encoder Stack\n",
    "encoder_stacks = nn.ModuleList([\n",
    "    EncoderBlock(d_model, multi_head_attention, feed_forward)\n",
