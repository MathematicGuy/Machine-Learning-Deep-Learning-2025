    "class ProjectionLayer(nn.Module):\n",
    "    def __init__(self, d_model: int, vocab_size: int) -> None:\n",
    "        \"\"\"Map model representation to class logits to reuse for muli-purpose\n",
    "\n",
    "        Args:\n",
    "            d_model (int): torch.Tensor, token embeding dimension\n",
    "            vocab_size (int): int, size of the entire vocabulary the model trained on\n",
    "        \"\"\"\n",
    "        super().__init__()\n",
    "        #? mix and refine these combined features.\n",
    "        self.project = nn.Linear(d_model, vocab_size)\n",
    "\n",
    "    def forward(self, x: torch.Tensor):\n",
    "        \"\"\"Forward pass for proj layer\n",
    "\n",
    "        Args:\n",
    "            x (torch.Tensor): Input tensor from Decoder\n",
    "                            shape(batch_size, seq_len, d_model)\n",
    "\n",
    "        Returns:\n",
    "            torch.Tensor: tensor logits\n",
    "        \"\"\"\n",
    "        return self.project(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0f4d39a3",
   "metadata": {},
   "outputs": [],
   "source": [
    "class Transformer(nn.Module):\n",
    "    def __init__(self, encoder: Encoder, decoder: Decoder, src_embed: InputEmbedding, tgt_embed: InputEmbedding, src_pos: PositionalEncoding, tgt_pos: PositionalEncoding, projection_layer: ProjectionLayer) -> None:\n",
    "        super().__init__()\n",
    "\n",
    "        self.encoder = encoder\n",
    "        self.decoder = decoder\n",
    "        self.src_embed = src_embed\n",
    "        self.tgt_embed = tgt_embed\n",
    "        self.src_pos = src_pos\n",
    "        self.tgt_pos = tgt_pos\n",
    "        self.projection_layer = projection_layer\n",
    "\n",
    "    def encode(self, src: torch.Tensor, src_mask: torch.Tensor):\n",
    "        src = self.src_embed(src)\n",
    "        src = self.src_pos(src)\n",
    "\n",
    "        return encoder(src, src_mask)\n",
    "\n",
    "    def decode(self, tgt: torch.Tensor, src_encoder: torch.Tensor, src_mask: torch.Tensor, tgt_mask: torch.Tensor):\n",
    "        tgt = self.tgt_embed(tgt)\n",
    "        tgt = self.tgt_pos(tgt)\n",
    "\n",
    "        return decoder(tgt, src_encoder, src_mask, tgt_mask)\n",
    "\n",
    "    def project(self, x: torch.Tensor):\n",
    "        return self.projection_layer(x)"
   ]
  },
